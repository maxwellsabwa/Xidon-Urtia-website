{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price in Ksh" },
        "image": { "type": "string", "description": "Product image URL" },
        "category": { "type": "string", "description": "Product category" },
        "description": { "type": "string", "description": "Product description" },
        "stock": { "type": "integer", "description": "Available stock" }
      },
      "required": ["name", "price", "image", "category", "stock"]
    },
    "PageContent": {
      "title": "PageContent",
      "description": "Content for a specific page",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "heroImage": { "type": "string" }
      },
      "required": ["heroTitle", "heroSubtitle", "heroImage"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerName", "customerEmail", "items", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/pageContent/{pageId}": {
      "schema": "PageContent",
      "description": "Content for pages like home, about, etc."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    }
  }
}
