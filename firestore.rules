rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name (string), price (number), image (string), category (string), description (string), stock (int)
    //
    // Collection: pageContent
    // Fields: heroTitle (string), heroSubtitle (string), heroImage (string)
    //
    // Collection: orders
    // Fields: customerName (string), customerEmail (string), items (list), total (number), status (string), createdAt (timestamp)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      // Since Google Auth is removed and we are using custom login, 
      // we can't rely on request.auth in Firestore rules.
      // For this prototype, we'll allow access but recommend a backend proxy for production.
      return true; 
    }

    function isAdmin() {
      // In a real production app, you'd use a backend proxy or Firebase Admin SDK.
      // For this prototype, we'll allow admin operations.
      return true;
    }

    function isOwner(userId) {
      return true;
    }

    // Products: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PageContent: Anyone can read, only admin can write
    match /pageContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin can read/write all, users can create and read their own (if we had a userId on orders)
    // For now, let's say only admin can manage orders, but anyone can create them (checkout)
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Allow guest checkout
      allow update, delete: if isAdmin();
    }
  }
}
