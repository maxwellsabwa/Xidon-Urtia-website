rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name (string), price (string), image (string), category (string), description (string), stock (int)
    //
    // Collection: pageContent
    // Fields: heroTitle (string), heroSubtitle (string), heroImage (string)
    //
    // Collection: orders
    // Fields: customerName (string), customerEmail (string), items (list), total (number), status (string), createdAt (timestamp)
    //
    // Collection: users
    // Fields: email (string), role (string: 'admin'|'user'), createdAt (timestamp)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "maxwellsabwa@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Domain Validators
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'image', 'category']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is string &&
             data.image is string &&
             data.category is string &&
             (!('stock' in data) || data.stock is int) &&
             (!('featured' in data) || data.featured is bool);
    }

    // Users: Only owner or admin can read/write
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Only admin can set roles, but user can create their own profile with 'user' role
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
      allow delete: if isAdmin();
    }

    // Products: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    // PageContent: Anyone can read, only admin can write
    match /pageContent/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin can read/write all, anyone can create (checkout)
    match /orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true; // Guest checkout allowed
      allow update, delete: if isAdmin();
    }
  }
}
